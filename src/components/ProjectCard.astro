---
// ProjectCard.astro
interface Props {
    title: string;
    description: string;
    tags: string[];
}

const { title, description, tags } = Astro.props;
---

<div class="group h-full">
    <div
        class="relative overflow-hidden rounded-md border bg-card-bg/50 border-card-border transition-all duration-300 h-full"
    >
        <div class="p-6">
            <h3 class="font-mono text-lg mb-3">{title}</h3>
            <p class="text-neutral-300 mb-4">{description}</p>
            <div class="flex flex-wrap gap-2 mt-4">
                {
                    tags.map((tag) => (
                        <span class="px-2 py-1 bg-blue-500/10 text-blue-400 rounded text-xs font-mono">
                            {tag}
                        </span>
                    ))
                }
            </div>
        </div>
    </div>
</div>
