---
import MainLayout from "@/layouts/MainLayout.astro";
const basePath = import.meta.env.BASE_URL || "/";
---

<MainLayout
    title="404: Page Not Found | t128n"
    description="The page you're looking for doesn't exist or has been moved."
    canonicalURL={new URL("/404", Astro.site)}
>
    <main class="w-full max-w-[900px] mx-auto px-6 py-12 text-center">
        <section class="py-16 flex flex-col items-center">
            <h1
                class="font-mono text-5xl font-semibold tracking-tight text-neutral-50 mb-6"
            >
                404
            </h1>
            <h2 class="text-blue-400 text-xl font-medium mb-8">
                Page Not Found
            </h2>
            <p class="text-neutral-300 max-w-lg mx-auto leading-relaxed mb-10">
                The page you're looking for doesn't exist or has been moved.
            </p>
            <a
                href={basePath}
                class="px-4 py-2 bg-blue-500 text-white rounded-md transition-colors hover:bg-blue-600"
            >
                Return Home
            </a>
        </section>
    </main>
</MainLayout>
