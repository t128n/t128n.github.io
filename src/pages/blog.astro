---
import MainLayout from "../layouts/MainLayout.astro";
import { getCollection, getEntry } from "astro:content";
import type { CollectionEntry } from "astro:content";

// Define a type for our blog post
type BlogPost = CollectionEntry<"blog">;

// Get the base path for links
const basePath = import.meta.env.BASE_URL || "/t128n";

// Format date for display - defined outside try/catch
const formatDate = (date: Date): string => {
    return date.toLocaleDateString("en-US", {
        month: "short",
        day: "numeric",
    });
};

// Format full date for the right column - defined outside try/catch
const formatFullDate = (date: Date): string => {
    return date.toLocaleDateString("en-US", {
        year: "numeric",
        month: "short",
        day: "numeric",
    });
};

// Declare variables that will be used in the template
let sortedYears: string[] = [];
let postsByYear: Record<string, BlogPost[]> = {};

try {
    // Get all blog posts from the collection
    const allBlogPosts = await getCollection("blog");

    console.log("Blog collection access successful");
    console.log(`Total posts found: ${allBlogPosts.length}`);

    // Filter out draft posts in production
    const publishedBlogPosts = allBlogPosts.filter(
        (post) => import.meta.env.DEV || !post.data.draft,
    );

    // Sort posts by publish date (newest first)
    const sortedPosts = publishedBlogPosts.sort(
        (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
    );

    // Group posts by year
    interface PostsByYear {
        [key: string]: BlogPost[];
    }

    postsByYear = sortedPosts.reduce((acc: PostsByYear, post) => {
        const year = post.data.publishDate.getFullYear().toString();
        if (!acc[year]) {
            acc[year] = [];
        }
        acc[year].push(post);
        return acc;
    }, {} as PostsByYear);

    // Sort years in descending order
    sortedYears = Object.keys(postsByYear).sort(
        (a, b) => Number(b) - Number(a),
    );

    console.log(`Published posts: ${publishedBlogPosts.length}`);
    console.log(`Years with posts: ${sortedYears.join(", ")}`);
} catch (error) {
    const errorMessage = error instanceof Error ? error.message : String(error);
    console.error("Error accessing blog collection:", errorMessage);
}
---

<MainLayout
    title="Blog | t128n"
    description="Thoughts, ideas, and explorations from Torben Haack - a collection of articles on software engineering, architecture, and technical insights."
    canonicalURL={new URL("/blog", Astro.site)}
>
    <main class="w-full max-w-[900px] mx-auto px-6 py-10 font-mono">
        <article class="w-full text-sm text-neutral-800 dark:text-neutral-200">
            <header class="flex justify-between items-center py-6">
                <h1 class="text-lg font-medium">Blog</h1>
                <div class="text-sm text-neutral-500 dark:text-neutral-400">
                    Thoughts, ideas, and explorations
                </div>
            </header>

            <section class="mt-8">
                {
                    sortedYears.length > 0 ? (
                        sortedYears.map((year) => (
                            <div class="mb-10">
                                <div class="grid grid-cols-[80px_1fr_120px] gap-4 py-2 text-neutral-400 dark:text-neutral-500 border-t border-neutral-200 dark:border-neutral-800">
                                    <div>{year}</div>
                                    <div />
                                    <div class="text-right">published</div>
                                </div>

                                {postsByYear[year].map((post) => (
                                    <div class="grid grid-cols-[80px_1fr_120px] gap-4 py-4 border-t border-neutral-100 dark:border-neutral-800/50">
                                        <div class="text-neutral-400 dark:text-neutral-500">
                                            {formatDate(post.data.publishDate)}
                                        </div>
                                        <div>
                                            <a
                                                href={`${basePath}/blog/${post.slug}`}
                                                class="hover:underline hover:text-blue-500 dark:hover:text-blue-400 transition-colors duration-200"
                                            >
                                                {post.data.title}
                                            </a>
                                        </div>
                                        <div class="text-right text-neutral-400 dark:text-neutral-500">
                                            {formatFullDate(
                                                post.data.publishDate,
                                            )}
                                        </div>
                                    </div>
                                ))}
                            </div>
                        ))
                    ) : (
                        <div class="py-8 text-center text-neutral-500 dark:text-neutral-400">
                            <p>
                                No blog posts available yet. Please check the
                                console for any content collection errors.
                            </p>
                        </div>
                    )
                }
            </section>
        </article>
    </main>
</MainLayout>
